msgid "Failed to delete announcement"
msgstr ""

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:33
msgid "Get announcement"
msgstr "お知らせを取得"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:40
msgid "Get the details of a single course announcement by its ID."
msgstr "ID を指定して単一のコースのお知らせの詳細を取得します。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:53
#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:69
msgid "The announcement ID."
msgstr "お知らせ ID。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:77
msgid "The announcement content (HTML)."
msgstr "お知らせの本文（HTML）。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:81
msgid "The post status, e.g. publish, future, draft."
msgstr "投稿ステータス（例：publish、future、draft）。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:85
#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:73
msgid "The publish date (Y-m-d H:i:s, site timezone)."
msgstr "公開日時（Y-m-d H:i:s、サイトのタイムゾーン）。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:89
msgid "The course ID this announcement belongs to."
msgstr "このお知らせが属するコース ID。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:97
msgid "Expiration time as a 10-digit Unix timestamp, or an empty string when it never expires."
msgstr "有効期限（10 桁の Unix タイムスタンプ）。無期限の場合は空文字列。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:101
msgid "Computed status label: active, scheduled, expired or draft."
msgstr "算出されたステータスラベル：active、scheduled、expired または draft。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementGetTool.php:151
#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:145
#: inc/classes/Resources/Announcement/Core/Api.php:95
msgid "Announcement does not exist"
msgstr ""

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:33
msgid "List announcements"
msgstr "お知らせ一覧"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:40
msgid "List course announcements. Supports filtering by course, by post status, and pagination."
msgstr "コースのお知らせを一覧表示します。コース別・投稿ステータス別の絞り込みとページネーションに対応しています。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:53
msgid "The course ID that owns the announcements. When omitted, announcements from all courses are returned."
msgstr "お知らせが属するコース ID。省略した場合はすべてのコースのお知らせを返します。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:57
msgid "Comma-separated post statuses to include. One or more of: publish, future, draft, pending, private, trash. Defaults to publish,future,draft."
msgstr "対象とする投稿ステータスをカンマ区切りで指定します。publish、future、draft、pending、private、trash のいずれか一つ以上。既定値は publish,future,draft です。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:64
msgid "Number of announcements per page."
msgstr "1 ページあたりのお知らせ件数。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:70
msgid "Page number, starting from 1."
msgstr "ページ番号（1 から開始）。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:86
msgid "The list of announcements."
msgstr "お知らせの一覧。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementListTool.php:93
msgid "Number of announcements returned in this page."
msgstr "このページで返されたお知らせの件数。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:36
msgid "Update announcement"
msgstr "お知らせを更新"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:43
msgid "Update a course announcement. Only the fields you provide are changed; omitted fields are left untouched."
msgstr "コースのお知らせを更新します。指定したフィールドのみ変更され、省略したフィールドは変更されません。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:56
msgid "The announcement ID to update."
msgstr "更新するお知らせ ID。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:87
msgid "Expiration time as a 10-digit Unix timestamp, must be later than post_date. Pass an empty string to clear it."
msgstr "有効期限（10 桁の Unix タイムスタンプ）。post_date より後である必要があります。空文字列を渡すと解除されます。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:103
msgid "The ID of the updated announcement."
msgstr "更新されたお知らせの ID。"

#: inc/classes/Api/Mcp/Tools/Announcement/AnnouncementUpdateTool.php:177
#: inc/classes/Api/Mcp/Tools/Email/EmailUpdateTool.php:214
msgid "No updatable fields were provided."
msgstr "更新可能なフィールドが指定されていません。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:33
msgid "移除銷售方案商品"
msgstr "販売プラン商品を削除"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:40
msgid "清空銷售方案內的所有 bundled IDs（未提供 product_ids 時），或僅移除指定的商品 IDs。同時會清除已廢棄的 exclude_main_course meta。"
msgstr "販売プラン内のすべての bundled IDs をクリア（product_ids が指定されていない場合）するか、指定された商品 IDs のみを削除します。同時に廃止された exclude_main_course メタもクリアします。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:56
#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:54
#: inc/classes/Api/Mcp/Tools/Bundle/BundleSetProductsTool.php:56
msgid "銷售方案商品 ID"
msgstr "販売プラン商品 ID"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:64
msgid "欲移除的商品 ID 列表；若未提供或為空，則清空所有 bundled IDs。"
msgstr "削除する商品 ID のリスト。指定されていないか空の場合、すべての bundled IDs をクリアします。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:117
#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:113
#: inc/classes/Api/Mcp/Tools/Bundle/BundleSetProductsTool.php:122
#: inc/classes/Api/Mcp/Tools/Order/OrderGetTool.php:111
msgid "id 為必填且需為正整數。"
msgstr "id は必須で、正の整数である必要があります。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:126
#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:122
#: inc/classes/Api/Mcp/Tools/Bundle/BundleSetProductsTool.php:174
msgid "找不到指定的商品。"
msgstr "指定された商品が見つかりません。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleDeleteProductsTool.php:135
#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:131
#: inc/classes/Api/Mcp/Tools/Bundle/BundleSetProductsTool.php:183
msgid "指定的商品不是銷售方案（bundle_type 為空）。"
msgstr "指定された商品は販売プランではありません（bundle_type が空です）。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:31
msgid "取得銷售方案"
msgstr "販売プランを取得"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleGetTool.php:38
msgid "取得單一銷售方案的完整資訊，包含綁定課程、包含的商品 ID 列表（含向下相容）、以及每個商品的數量配置。"
msgstr "単一の販売プランの完全な情報を取得します。バンドルされたコース、含まれる商品 ID リスト（後方互換性を含む）、および各商品の数量設定を含みます。"

#: inc/classes/Api/Mcp/Tools/Bundle/BundleListTool.php:30
msgid "列出銷售方案"
